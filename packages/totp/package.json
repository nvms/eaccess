{
  "name": "@eaccess/totp",
  "version": "1.0.4",
  "description": "TOTP generation and verification for @eaccess/auth",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "totp",
    "otp",
    "2fa",
    "authentication"
  ],
  "author": "Jonathan Pyers",
  "license": "MIT",
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "qrcode": "^1.5.4",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@scure/base": "^2.0.0"
  }
}
